{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "globals": {
    "Chart": "readonly",
    "Clusterize": "readonly",
    "jsQR": "readonly",
    "showAppAlert": "readonly",
    "showAppConfirm": "readonly",
    "showAppChoice": "readonly",
    "toggleChildren": "readonly",
    "openStatusModal": "readonly",
    "deleteRecord": "readonly",
    "restoreRecord": "readonly",
    "purgeRecord": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-constant-condition": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-extra-semi": "error",
    "no-redeclare": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-unreachable": "warn",
    "eqeqeq": ["error", "always"],
    "no-var": "warn",
    "prefer-const": ["warn", { "destructuring": "all" }],
    "curly": ["warn", "multi-line"],
    "no-throw-literal": "error",
    "no-self-compare": "error",
    "no-template-curly-in-string": "warn"
  },
  "ignorePatterns": ["node_modules/", "public/lib/"]
}
