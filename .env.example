# DayCost Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Generate secrets with:
#   openssl rand -hex 32

# ─── Required ────────────────────────────────────────────────────────────────

# JWT Secret for authentication tokens (REQUIRED — server will not start without it)
# Must be at least 32 characters for adequate security.
JWT_SECRET=your_jwt_secret_here_at_least_32_characters

# TOTP Encryption Key for 2FA secrets (REQUIRED in production)
# Must be exactly 32 UTF-8 bytes (32 ASCII characters or 32 UTF-8 encoded bytes).
# In development mode: if not set, a key is auto-generated and persisted to .env.local
#   so TOTP secrets survive restarts. In production, this MUST be set explicitly.
TOTP_KEY=your_totp_key_here_exactly_32_bytes

# ─── Optional ────────────────────────────────────────────────────────────────

# HTTP server port (default: 80)
PORT=80

# HTTPS server port (default: 3443, only active if cert.pem + key.pem exist)
HTTPS_PORT=3443

# SQLite database file path (default: ./data.db relative to project root)
DB_PATH=./data.db

# CORS allowed origins (comma-separated; default in dev: http://localhost:3000)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Node environment (default: development; set to "production" for production)
# NODE_ENV=production
